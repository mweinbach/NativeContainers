[Unit]
Description=NativeContainers Linux box guest agent
Requires=nativecontainers-baseline-firewall.service nativecontainers-grow-root.service
After=nativecontainers-baseline-firewall.service nativecontainers-grow-root.service local-fs.target
Before=nativecontainers-network-authorization.service systemd-networkd.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /usr/local/libexec/nativecontainers_agent.py
ExecStopPost=/usr/bin/python3 /usr/local/libexec/nativecontainers_lockdown.py
Restart=on-failure
RestartSec=1s
RuntimeDirectory=nativecontainers
RuntimeDirectoryMode=0700
UMask=0077
StandardOutput=null
StandardError=null
LimitCORE=0
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/run/nativecontainers /workspace
CapabilityBoundingSet=CAP_CHOWN CAP_DAC_OVERRIDE CAP_FOWNER CAP_KILL CAP_NET_ADMIN CAP_NET_BIND_SERVICE CAP_SETGID CAP_SETUID CAP_SYS_ADMIN CAP_SYS_RESOURCE
AmbientCapabilities=

[Install]
WantedBy=multi-user.target
